<?xml version="1.0" encoding="utf-8"?>
<!-- AndroidManifest.xml for Communication Class -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.communicationclass.game"
    android:versionCode="1"
    android:versionName="0.1.0">

    <uses-sdk android:minSdkVersion="30" android:targetSdkVersion="36" />

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.HAND_TRACKING" />

    <!-- Android XR Features -->
    <uses-feature
        android:name="android.software.xr.api.level"
        android:required="true"
        android:version="1" />
    <uses-feature
        android:name="android.hardware.xr.handtracking"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.xr.spatial_anchoring"
        android:required="false" />

    <application
        android:debuggable="false"
        android:hasCode="false"
        android:label="Communication Class">

        <activity
            android:name="android.app.NativeActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="true">

            <meta-data android:name="android.app.lib_name" android:value="communication_class" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.XR_ACTIVITY" />
                <category android:name="android.intent.category.XR_DEFAULT" />
            </intent-filter>
        </activity>
    </application>
</manifest>
